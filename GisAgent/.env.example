# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# GIS Places API — local: http://127.0.0.1:8000  |  Azure: your Container Apps URL
GIS_API_BASE_URL=

# Agent behaviour
MAX_TOOL_ROUNDS=5
LOG_LEVEL=INFO

# Agent HTTP server (for GisPortal intelligent search)
